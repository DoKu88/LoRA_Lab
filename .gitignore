# Local Claude Code / agent tooling config
.claude/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
build/
dist/

# --- training run outputs (heavy, regenerable) -----------------------------
# Trained weights / checkpoints are NOT committed. Per-run memory traces and
# the gpu-mem-vs-iteration plots are regenerable (mem_trace from results/runs,
# plots via build_table.py) and churn on every run, so they are NOT tracked.
results/runs/
results/mem_trace/
results/plots/
wandb/

# Tracked: the curated deliverable only —
#   results/comparison.csv / .parquet / .md  (the Phase 0 table/dataset)

# HF / model caches if they ever land in-tree
.cache/
hf_cache/

# Phase 0.5 intermediates (regenerable); the feasibility_table.* and plots/ ARE committed
results/phase05/runs/
results/phase05/mem_trace/

# Phase 1 intermediates. Committed: configs/phase1/*.yaml (manifest + locked split),
# library_quality.* (gate table), gate_results.jsonl, oracles.json. NOT committed:
# the oracle LoRA checkpoints + wandb (heavy, regenerable from the committed config
# + seed 42 — see docs/phase-1-findings.md reproducibility recipe) and run logs.
results/phase1/oracles/
results/phase1/*.log

# Phase 2 run outputs (hypernet checkpoints — heavy, regenerable from config+seed)
results/phase2/runs/
results/phase2/*.log
